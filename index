const SMSGS = ['Nosem, pomalu a hluboce...', 'Zadrž — nech klid přijít...', 'Ústy, plynule a úplně...'];
function startStr() { show('sc-str'); strRunning = true; sPhaseIdx = 0; sTick = 0; sCycle = 0; updSP(); clearInterval(strIv); strIv = setInterval(tickStr, 1000); }
function updSP() { const ph = SPHASES[sPhaseIdx]; document.getElementById('s-num').textContent = ph.d; document.getElementById('s-lbl').textContent = ph.n.toUpperCase(); document.querySelectorAll('[id^="sd"]').forEach(d => d.classList.remove('on')); document.getElementById('sd' + sPhaseIdx).classList.add('on'); document.getElementById('s-bub').textContent = SMSGS[sPhaseIdx]; tone(528, .22); const orb = document.getElementById('s-orb'), core = document.getElementById('s-orbc'); if (sPhaseIdx === 0) { orb.style.transform = 'scale(1.08)'; orb.style.borderColor = 'rgba(77,168,212,.38)'; core.style.transform = 'scale(1.2)'; } else if (sPhaseIdx === 1) { orb.style.transform = 'scale(1.14)'; orb.style.borderColor = 'rgba(126,232,212,.35)'; core.style.transform = 'scale(1.3)'; } else { orb.style.transform = 'scale(.87)'; orb.style.borderColor = 'rgba(240,192,96,.28)'; core.style.transform = 'scale(.65)'; } }
function tickStr() { if (!strRunning) return; sTick++; const rem = SPHASES[sPhaseIdx].d - sTick; document.getElementById('s-num').textContent = rem > 0 ? rem : ''; if (sTick >= SPHASES[sPhaseIdx].d) { sTick = 0; sPhaseIdx = (sPhaseIdx + 1) % 3; if (sPhaseIdx === 0) { sCycle++; document.getElementById('s-cyc').textContent = `Kolo ${sCycle + 1} / 4`; if (sCycle >= 4) { stopStr(true); return; } } updSP(); } }
function stopStr(done) { strRunning = false; clearInterval(strIv); incLc('str'); addHist({ type: 'str', date: new Date().toLocaleDateString('cs-CZ') }); if (done) success(); showCalm(done ? '4 kola 4-7-8 dokončena! Parasympatický systém aktivován.' : 'Dobrá práce! Vědomě dýchat znamená žít.', done ? 'Stres — splněno ✓' : 'Stres'); }

// ═══════════════════════════ CALM DONE ═══════════════════════════
function showCalm(msg, title) { document.getElementById('calm-t').textContent = title; document.getElementById('calm-m').textContent = msg; document.getElementById('calm-ff').textContent = FACTS[Math.floor(Math.random() * FACTS.length)]; show('sc-calm'); }
function logMood(el, mood) { document.querySelectorAll('.mood-btn').forEach(d => { d.style.opacity = '.45'; d.style.transform = ''; }); el.style.opacity = '1'; el.style.transform = 'scale(1.06)'; setTimeout(() => document.getElementById('calm-m').textContent = 'Nálada: ' + mood + ' — zaznamenáno!', 220); }

// ═══════════════════════════ STOP ALL ═══════════════════════════
function stopAll() { holdRunning = false; boxRunning = false; strRunning = false; clearInterval(holdIv); clearInterval(boxIv); clearInterval(strIv); clearInterval(bblIv); clearInterval(cdIv); clearInterval(dotAnimIv); }

// ═══════════════════════════ INIT ═══════════════════════════
(function init() {
  setRandomPlaceholder();
  const p = lsGet('profile');
  if (p && p.nick) { P = p; refreshDash(); show('sc-dash'); }
})();
</script>
