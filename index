<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Breatheflow — učíme tě dýchat. Dechová cvičení od základů až po pokročilé techniky.">
<title>Breatheflow 1.0.3</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
:root{--a:#4da8d4;--tl:#7ee8d4;--am:#f0c060;--gn:#5edba0;--mid:#050f1a;--gl:rgba(10,42,61,.52);--gb:rgba(77,168,212,.2);--tb:#e8f4f8;--tm:#8ec8e8;--td:#4a8aaa;}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--mid);color:var(--tb);min-height:100vh;overflow-x:hidden;}
.brand-header{position:fixed;top:11px;right:52px;z-index:150;font-size:10px;color:rgba(77,168,212,.45);letter-spacing:1.5px;text-transform:uppercase;pointer-events:none;}
.bg{position:fixed;inset:0;background:radial-gradient(ellipse at 50% 0%,#0d3550 0%,#05121e 55%,#020810 100%);z-index:0;}
.aurora{position:fixed;top:0;left:0;right:0;height:200px;background:linear-gradient(180deg,rgba(0,180,160,.07),rgba(30,120,200,.05) 40%,transparent);animation:aur 14s ease-in-out infinite;z-index:1;pointer-events:none;}
@keyframes aur{0%,100%{opacity:.5;}50%{opacity:1;}}
.wvbg{position:fixed;inset:0;z-index:1;pointer-events:none;}
.wv{position:absolute;border-radius:50%;border:1px solid rgba(77,168,212,.07);transform:translate(-50%,-50%);left:50%;top:50%;animation:bwv 9s ease-in-out infinite;}
.wv:nth-child(1){width:160px;height:160px;}
.wv:nth-child(2){width:380px;height:380px;animation-delay:2s;border-color:rgba(77,168,212,.04);}
.wv:nth-child(3){width:650px;height:650px;animation-delay:4s;border-color:rgba(77,168,212,.02);}
@keyframes bwv{0%,100%{opacity:.3;transform:translate(-50%,-50%) scale(.97);}50%{opacity:1;transform:translate(-50%,-50%) scale(1.03);}}
.pts{position:fixed;inset:0;z-index:1;pointer-events:none;}
.pt{position:absolute;background:rgba(232,244,248,.4);border-radius:50%;animation:pf linear infinite;}
@keyframes pf{0%{transform:translateY(100vh) scale(0);opacity:0;}10%{opacity:.7;}90%{opacity:.2;}100%{transform:translateY(-20px) translateX(12px) scale(1);opacity:0;}}
.footer{position:fixed;bottom:10px;left:0;right:0;text-align:center;font-size:10px;color:rgba(77,168,212,.3);letter-spacing:1px;z-index:150;pointer-events:none;}
.app{position:relative;z-index:10;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:0 14px 70px;}
.scr{display:none;width:100%;max-width:450px;flex-direction:column;align-items:center;animation:fu .35s ease;}
.scr.on{display:flex;}
@keyframes fu{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.gl{background:var(--gl);border:1px solid var(--gb);border-radius:20px;backdrop-filter:blur(22px);position:relative;overflow:hidden;}
.gl::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(232,244,248,.15),transparent);}
.pb{width:100%;max-width:450px;height:2px;background:rgba(77,168,212,.1);border-radius:1px;margin-bottom:4px;}
.pf{height:100%;background:linear-gradient(90deg,#0a2a3d,var(--a));border-radius:1px;transition:width .5s;}
.brand{font-size:30px;font-weight:300;letter-spacing:5px;text-transform:uppercase;}
.brand span{color:var(--a);font-weight:700;}
.sub{font-size:9px;color:var(--td);letter-spacing:3px;text-transform:uppercase;}
.btn{width:100%;max-width:350px;padding:13px 22px;border-radius:13px;font-family:inherit;font-size:12px;font-weight:500;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .2s;border:none;outline:none;}
.btn-p{background:linear-gradient(135deg,rgba(77,168,212,.25),rgba(30,111,163,.35));border:1px solid rgba(77,168,212,.35);color:var(--tb);}
.btn-p:hover{border-color:rgba(77,168,212,.6);transform:translateY(-1px);}
.btn-stop{background:rgba(200,70,70,.12);border:1px solid rgba(200,70,70,.28);color:#f08080;}
.btn-stop:hover{background:rgba(200,70,70,.2);}
.btn-g{background:transparent;border:1px solid rgba(77,168,212,.15);color:var(--td);font-size:11px;padding:9px 16px;}
.btn-g:hover{color:var(--tm);border-color:rgba(77,168,212,.3);}
.btn-navy{background:linear-gradient(135deg,rgba(30,80,30,.4),rgba(20,60,20,.5));border:1px solid rgba(94,219,160,.35);color:var(--gn);letter-spacing:2px;}
.btn-navy:hover{border-color:rgba(94,219,160,.6);transform:translateY(-1px);}
.fi{background:rgba(77,168,212,.06);border:1px solid rgba(77,168,212,.17);border-radius:11px;padding:11px 13px;color:var(--tb);font-family:inherit;font-size:14px;outline:none;transition:all .22s;width:100%;}
.fi:focus{border-color:var(--a);background:rgba(77,168,212,.12);box-shadow:0 0 0 3px rgba(77,168,212,.07);}
.fi::placeholder{color:rgba(77,168,212,.45);font-style:italic;}
.fw{margin-bottom:12px;}
.fl{font-size:9px;color:var(--td);letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;display:block;}
.ph-hint{font-size:10px;color:rgba(77,168,212,.35);letter-spacing:1px;margin-top:4px;font-style:italic;}
.gg{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;}
.gbtn{padding:9px 5px;background:rgba(77,168,212,.04);border:1px solid rgba(77,168,212,.11);border-radius:9px;color:var(--td);font-family:inherit;font-size:13px;cursor:pointer;transition:all .22s;text-align:center;}
.gbtn.on{background:rgba(77,168,212,.2);border-color:var(--a);color:#b8ddf0;box-shadow:0 0 10px rgba(77,168,212,.16);}
.exc{display:flex;flex-direction:column;gap:7px;}
.ec{padding:13px 15px;background:rgba(77,168,212,.04);border:1px solid rgba(77,168,212,.1);border-radius:11px;cursor:pointer;transition:all .22s;position:relative;display:flex;align-items:center;gap:12px;}
.ec:hover:not(.disabled){background:rgba(77,168,212,.12);border-color:rgba(77,168,212,.3);transform:translateY(-1px);}
.ec.disabled{opacity:.38;cursor:not-allowed;}
.ec-icon{font-size:22px;flex-shrink:0;}
.ec-text{flex:1;}
.en{font-size:13px;color:var(--tb);font-weight:600;margin-bottom:2px;}
.ed{font-size:11px;color:var(--td);}
.ebadge{font-size:8px;letter-spacing:1px;padding:2px 7px;border-radius:4px;}
.ebadge-avail{background:rgba(77,168,212,.13);color:var(--a);}
.ebadge-soon{background:rgba(100,100,100,.18);color:#666;}
.ec-arrow{font-size:14px;color:var(--td);flex-shrink:0;}
.dots{display:flex;gap:6px;align-items:center;}
.dot{width:6px;height:6px;border-radius:50%;background:rgba(77,168,212,.15);transition:all .35s;}
.dot.on{background:var(--a);width:18px;border-radius:3px;}
.bub{background:rgba(77,168,212,.08);border:1px solid rgba(77,168,212,.15);border-radius:12px;padding:11px 16px;font-size:13px;color:var(--tm);text-align:center;line-height:1.6;max-width:280px;}
.twrap{position:relative;width:210px;height:210px;}
.tsv{width:100%;height:100%;transform:rotate(-90deg);}
.trk{fill:none;stroke:rgba(77,168,212,.1);stroke-width:5;}
.prg{fill:none;stroke:var(--a);stroke-width:5;stroke-linecap:round;stroke-dasharray:659.73;stroke-dashoffset:0;transition:stroke-dashoffset 1s linear,stroke .5s;}
.prg.hl{stroke:var(--tl);filter:drop-shadow(0 0 10px rgba(126,232,212,.55));}
.prg.ex{stroke:var(--am);}
.tin{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;}
.tnum{font-size:46px;font-weight:300;color:var(--tb);line-height:1;letter-spacing:-2px;}
.tlbl{font-size:9px;color:var(--td);letter-spacing:2px;text-transform:uppercase;}
.sgrid4{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;width:100%;}
.sgrid3{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;width:100%;}
.sc{background:rgba(77,168,212,.06);border:1px solid rgba(77,168,212,.1);border-radius:11px;padding:11px 7px;text-align:center;}
.sv{font-size:18px;font-weight:600;color:var(--tb);}
.sl2{font-size:8px;color:var(--td);letter-spacing:1px;margin-top:2px;}
.lrow{display:flex;align-items:center;justify-content:space-between;padding:9px 13px;background:rgba(77,168,212,.04);border-radius:9px;margin-bottom:6px;}
.lbrow{display:flex;align-items:center;gap:9px;padding:7px 11px;background:rgba(77,168,212,.04);border-radius:8px;margin-bottom:4px;}
.lbrow.me{background:rgba(77,168,212,.12);border:1px solid rgba(77,168,212,.2);}
.ff{background:rgba(77,168,212,.06);border:1px solid rgba(77,168,212,.15);border-radius:12px;padding:13px 15px;font-size:13px;color:var(--tm);line-height:1.65;width:100%;}
.fft{font-size:8px;color:rgba(77,168,212,.5);letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;}
.dive-scene{position:relative;width:100%;height:360px;border-radius:18px;overflow:hidden;}
.ocean{position:absolute;inset:0;background:linear-gradient(180deg,#071e2e 0%,#0b3c5c 30%,#082c46 65%,#041520 100%);}
.ray{position:absolute;top:0;width:2px;background:linear-gradient(180deg,rgba(77,168,212,.2),transparent);transform-origin:top center;}
.dl{position:absolute;left:0;right:0;height:1px;background:rgba(77,168,212,.1);}
.dlabel{position:absolute;right:12px;font-size:9px;color:rgba(77,168,212,.45);letter-spacing:1px;}
.dm{position:absolute;left:10px;top:10px;background:rgba(5,15,26,.75);border:1px solid rgba(77,168,212,.22);border-radius:9px;padding:7px 11px;}
.dmv{font-size:20px;font-weight:300;color:var(--tl);line-height:1;}
.dml{font-size:8px;color:var(--td);letter-spacing:1px;}
.bbl{position:absolute;border-radius:50%;border:1px solid rgba(200,240,255,.35);animation:bbl 2.2s ease-out infinite;}
@keyframes bbl{0%{opacity:0;transform:translateY(0) scale(.5);}30%{opacity:.75;}100%{opacity:0;transform:translateY(-50px) scale(1.3);}}
@keyframes dv{0%{transform:translateY(0) rotate(0deg);}100%{transform:translateY(300px) rotate(18deg);}}
.peng-diver{position:absolute;left:50%;top:16px;transform:translateX(-50%);animation:dv linear forwards;}
.tabs{display:flex;gap:6px;margin-bottom:11px;width:100%;}
.tab{flex:1;padding:7px;background:rgba(77,168,212,.04);border:1px solid rgba(77,168,212,.09);border-radius:7px;color:var(--td);font-size:10px;cursor:pointer;text-align:center;transition:all .2s;letter-spacing:1px;}
.tab.on{background:rgba(77,168,212,.14);border-color:var(--a);color:var(--tm);}
.cwrap{width:100%;height:90px;}
.orb{width:150px;height:150px;border-radius:50%;border:2px solid rgba(77,168,212,.22);display:flex;align-items:center;justify-content:center;transition:all 1s ease;}
.orb-c{width:70px;height:70px;border-radius:50%;background:radial-gradient(circle,rgba(77,168,212,.38),rgba(30,111,163,.18));transition:all 1s ease;}
.sndbtn{position:fixed;top:11px;right:14px;z-index:200;background:rgba(10,42,61,.8);border:1px solid rgba(77,168,212,.16);border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(12px);font-size:14px;}
.mood-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;position:relative;z-index:10;}
.mood-btn{padding:12px 6px;border-radius:9px;text-align:center;cursor:pointer;font-size:13px;transition:all .22s;border:1px solid transparent;position:relative;z-index:10;user-select:none;}
.navy-prep{width:100%;padding:22px 20px;}
.navy-title{font-size:11px;color:rgba(94,219,160,.6);letter-spacing:3px;text-transform:uppercase;margin-bottom:10px;}
.navy-body{font-size:14px;color:var(--tm);line-height:1.72;margin-bottom:20px;}
.navy-benefits{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:4px;}
.navy-benefits li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--tm);line-height:1.55;}
.navy-benefits li::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--gn);flex-shrink:0;margin-top:5px;}
.countdown-overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(5,15,26,.82);border-radius:16px;z-index:20;gap:10px;}
.countdown-num{font-family:'Oswald','Impact',sans-serif;font-size:80px;font-weight:700;color:var(--tb);line-height:1;animation:cdfade .7s ease;}
.countdown-sub{font-family:'Oswald','Impact',sans-serif;font-size:13px;font-weight:700;color:var(--td);letter-spacing:3px;text-transform:uppercase;margin-top:6px;}
@keyframes cdfade{from{opacity:0;transform:scale(1.25);}to{opacity:1;transform:scale(1);}}
.box-outer{position:relative;width:240px;height:240px;margin-bottom:6px;}
.box-label{position:absolute;font-size:9px;letter-spacing:2px;text-transform:uppercase;font-weight:600;transition:color .5s;}
.box-label-top{top:6px;left:50%;transform:translateX(-50%);}
.box-label-right{right:4px;top:50%;transform:translateY(-50%) rotate(90deg);}
.box-label-bottom{bottom:6px;left:50%;transform:translateX(-50%);}
.box-label-left{left:4px;top:50%;transform:translateY(-50%) rotate(-90deg);}
</style>
</head>
<body>

<div class="bg"></div>
<div class="aurora"></div>
<div class="wvbg"><div class="wv"></div><div class="wv"></div><div class="wv"></div></div>
<div class="pts" id="ptcl"></div>
<div class="brand-header">Breatheflow 1.0.3</div>
<div class="sndbtn" onclick="tglSnd()"><span id="sic">🔊</span></div>
<div class="footer">Michal Soulak</div>

<div class="app">

  <!-- ══════════════ ONBOARDING ══════════════ -->
  <div class="scr on" id="sc-ob">
    <div style="padding-top:44px;text-align:center;margin-bottom:28px;">
      <svg width="64" height="64" viewBox="0 0 70 70" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin:0 auto 12px;display:block;">
        <ellipse cx="35" cy="44" rx="20" ry="23" fill="#0a1a2a"/>
        <ellipse cx="35" cy="47" rx="11" ry="16" fill="#c8dff0"/>
        <ellipse cx="35" cy="22" rx="15" ry="14" fill="#0a1a2a"/>
        <circle cx="29" cy="19" r="3.5" fill="white"/><circle cx="41" cy="19" r="3.5" fill="white"/>
        <circle cx="29.8" cy="19.8" r="2.2" fill="#1a6fa3"/><circle cx="41.8" cy="19.8" r="2.2" fill="#1a6fa3"/>
        <circle cx="30.4" cy="19" r=".9" fill="white"/><circle cx="42.4" cy="19" r=".9" fill="white"/>
        <polygon points="35,24.5 31.5,28 38.5,28" fill="#f0a030"/>
        <ellipse cx="13" cy="43" rx="7" ry="14" fill="#0d2236" transform="rotate(-10,13,43)"/>
        <ellipse cx="57" cy="43" rx="7" ry="14" fill="#0d2236" transform="rotate(10,57,43)"/>
        <ellipse cx="27" cy="68" rx="8" ry="3.5" fill="#f0a030"/>
        <ellipse cx="43" cy="68" rx="8" ry="3.5" fill="#f0a030"/>
      </svg>
      <div class="brand">Breathe<span>flow</span></div>
      <div class="sub" style="margin-top:4px;">učíme tě dýchat</div>
    </div>
    <div class="gl" style="width:100%;padding:22px 18px;margin-bottom:14px;">
      <label class="fl">Přezdívka</label>
      <div class="fw">
        <input type="text" class="fi" id="ob-nick" maxlength="20">
        <div class="ph-hint" id="ph-hint"></div>
      </div>
      <label class="fl">Věk</label>
      <div class="fw"><input type="number" class="fi" id="ob-age" placeholder="25" min="10" max="99"></div>
      <label class="fl" style="margin-bottom:7px;">Pohlaví</label>
      <div class="gg">
        <button class="gbtn" onclick="selG(this,'m')">Muž</button>
        <button class="gbtn" onclick="selG(this,'f')">Žena</button>
        <button class="gbtn" onclick="selG(this,'x')">Jiné</button>
      </div>
    </div>
    <button class="btn btn-p" onclick="saveProf()">Začít →</button>
  </div>

  <!-- ══════════════ DASHBOARD ══════════════ -->
  <div class="scr" id="sc-dash">
    <div style="height:20px;"></div>
    <div style="width:100%;display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <div>
        <div style="font-size:9px;color:var(--td);letter-spacing:2px;text-transform:uppercase;">Vítej zpět</div>
        <div style="font-size:20px;font-weight:300;" id="d-name">—</div>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <svg width="38" height="38" viewBox="0 0 70 70" fill="none">
          <ellipse cx="35" cy="44" rx="20" ry="23" fill="#0a1a2a"/>
          <ellipse cx="35" cy="47" rx="11" ry="16" fill="#c8dff0"/>
          <ellipse cx="35" cy="22" rx="15" ry="14" fill="#0a1a2a"/>
          <circle cx="29" cy="19" r="3.5" fill="white"/><circle cx="41" cy="19" r="3.5" fill="white"/>
          <circle cx="29.8" cy="19.8" r="2.2" fill="#1a6fa3"/><circle cx="41.8" cy="19.8" r="2.2" fill="#1a6fa3"/>
          <polygon points="35,24.5 31.5,28 38.5,28" fill="#f0a030"/>
          <ellipse cx="13" cy="43" rx="7" ry="14" fill="#0d2236" transform="rotate(-10,13,43)"/>
          <ellipse cx="57" cy="43" rx="7" ry="14" fill="#0d2236" transform="rotate(10,57,43)"/>
          <ellipse cx="27" cy="68" rx="8" ry="3.5" fill="#f0a030"/>
          <ellipse cx="43" cy="68" rx="8" ry="3.5" fill="#f0a030"/>
        </svg>
        <button class="btn btn-g" style="width:auto;padding:7px 13px;" onclick="goOb()">Upravit</button>
      </div>
    </div>
    <div class="sgrid4" style="margin-bottom:12px;">
      <div class="sc"><div class="sv" id="d-tot">0</div><div class="sl2">Celkem lekcí</div></div>
      <div class="sc"><div class="sv" id="d-best">—</div><div class="sl2">Nejlepší čas</div></div>
      <div class="sc"><div class="sv" id="d-streak">0🔥</div><div class="sl2">Dní v řadě</div></div>
      <div class="sc"><div class="sv" id="d-conscious">0 min</div><div class="sl2">Vědomé dýchání</div></div>
    </div>
    <div class="gl" style="width:100%;padding:14px 12px;margin-bottom:12px;">
      <div style="font-size:8px;color:var(--td);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;">Výdrž přes dny (sek)</div>
      <div class="cwrap"><svg id="chart-svg" viewBox="0 0 400 90" width="100%" height="90" preserveAspectRatio="none"></svg></div>
    </div>
    <div style="font-size:9px;color:var(--td);letter-spacing:2px;text-transform:uppercase;margin-bottom:9px;align-self:flex-start;">Vyber cvičení</div>
    <div class="exc" style="width:100%;margin-bottom:12px;">
      <div class="ec" onclick="startHold()">
        <span class="ec-icon">🌊</span>
        <div class="ec-text">
          <div class="en">Maximální výdrž</div>
          <div class="ed">Zadrž dech — potápěč tučňák + žebříček</div>
          <div style="margin-top:4px;"><span class="ebadge ebadge-avail">DOSTUPNÉ</span></div>
        </div>
        <span class="ec-arrow">›</span>
      </div>
      <div class="ec" onclick="showNavyPrep()">
        <span class="ec-icon">🎯</span>
        <div class="ec-text">
          <div class="en">Navy SEALs Work</div>
          <div class="ed">Box breathing 4-4-4-4 — jako vojáci před zásahem</div>
          <div style="margin-top:4px;"><span class="ebadge ebadge-avail">DOSTUPNÉ</span></div>
        </div>
        <span class="ec-arrow">›</span>
      </div>
      <div class="ec" onclick="startStr()">
        <span class="ec-icon">🫧</span>
        <div class="ec-text">
          <div class="en">Práce se stresem</div>
          <div class="ed">Technika 4-7-8</div>
          <div style="margin-top:4px;"><span class="ebadge ebadge-avail">DOSTUPNÉ</span></div>
        </div>
        <span class="ec-arrow">›</span>
      </div>
      <div class="ec disabled">
        <span class="ec-icon" style="filter:grayscale(1);opacity:.5;">🕉️</span>
        <div class="ec-text">
          <div class="en" style="color:#666;">Tantrický dech</div>
          <div class="ed">Hluboká dechová meditace</div>
          <div style="margin-top:4px;"><span class="ebadge ebadge-soon">PŘIPRAVUJEME</span></div>
        </div>
      </div>
    </div>
